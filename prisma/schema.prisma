// Productivity — local content automation cockpit
// Prisma 7 rust-free ESM client. Import from "@/generated/prisma/client".

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth (single local user)
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
}

// ---------------------------------------------------------------------------
// App settings (singleton row, id = "singleton")
// ---------------------------------------------------------------------------

// Which local coding agent executes runs.
enum AgentProvider {
  CLAUDE
  CODEX
}

enum ClaudeAuthMode {
  SUBSCRIPTION
  API_KEY
}

model AppSetting {
  id             String         @id @default("singleton")
  provider       AgentProvider  @default(CLAUDE)
  defaultModel   String         @default("sonnet")
  claudeAuthMode ClaudeAuthMode @default(SUBSCRIPTION)
  // Codex engine defaults (used when provider = CODEX).
  codexModel           String @default("gpt-5.4")
  codexReasoningEffort String @default("medium")
  assetsRoot     String         @default("data/assets")
  tasksRoot      String         @default("data/tasks")
  updatedAt      DateTime       @updatedAt
}

// ---------------------------------------------------------------------------
// Workflows
// ---------------------------------------------------------------------------

model Workflow {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  platform          String   @default("instagram")
  description       String?
  globalInstruction String   @default("")
  defaultModel      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  schedules      Schedule[]
  assetFolders   AssetFolder[]
  globalAssets   WorkflowAsset[]
  tasks          Task[]
  workflowFonts  WorkflowFont[]
  workflowSkills WorkflowSkill[]
  campaigns      Campaign[]
}

// ---------------------------------------------------------------------------
// Schedules (cron)
// ---------------------------------------------------------------------------

enum Cadence {
  DAILY
  WEEKLY
  MONTHLY
}

model Schedule {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  cadence   Cadence
  cronExpr  String
  timeOfDay String   @default("09:00")
  timezone  String   @default("Asia/Jakarta")
  enabled   Boolean  @default(true)
  nextRunAt DateTime?
  lastRunAt DateTime?
  createdAt DateTime @default(now())

  tasks Task[]
  runs  TaskRun[]

  @@index([workflowId])
  @@index([enabled])
}

// ---------------------------------------------------------------------------
// Assets
// ---------------------------------------------------------------------------

model AssetFolder {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  name      String
  slug      String
  relPath   String
  notes     String?
  createdAt DateTime @default(now())

  assets    Asset[]
  tasks     Task[]
  campaigns Campaign[]

  @@unique([workflowId, slug])
  @@index([workflowId])
}

model Asset {
  id       String @id @default(cuid())
  folderId String
  folder   AssetFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  filename    String
  relPath     String
  mimeType    String
  size        Int
  width       Int?
  height      Int?
  description String @default("")
  // Retrieval keywords (auto-captioned or hand-entered) used by the asset
  // ranker to pick relevant photos per run without loading every image.
  tags          String[] @default([])
  // True when description/tags were produced by the caption assistant rather
  // than typed by the user.
  autoDescribed Boolean  @default(false)
  createdAt   DateTime @default(now())

  campaignItemAssets CampaignItemAsset[]

  @@index([folderId])
}

// Global, workflow-level assets reused across every task in the workflow
// (backgrounds, brand logos, SVG patterns).
enum WorkflowAssetKind {
  BACKGROUND
  LOGO
  PATTERN
  OTHER
}

model WorkflowAsset {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  filename    String
  relPath     String
  mimeType    String
  size        Int
  width       Int?
  height      Int?
  kind        WorkflowAssetKind @default(OTHER)
  description String            @default("")
  createdAt   DateTime          @default(now())

  @@index([workflowId])
}

// ---------------------------------------------------------------------------
// Tasks + runs
// ---------------------------------------------------------------------------

model Task {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  name          String
  instruction   String   @default("")
  assetFolderId String?
  assetFolder   AssetFolder? @relation(fields: [assetFolderId], references: [id], onDelete: SetNull)
  model         String?
  scheduleId    String?
  schedule      Schedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  runs         TaskRun[]
  campaignItem CampaignItem?

  @@index([workflowId])
  @@index([scheduleId])
}

enum RunStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
  CANCELLED
}

model TaskRun {
  id     String @id @default(cuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  status          RunStatus @default(QUEUED)
  outputRelPath   String?
  provider        AgentProvider @default(CLAUDE)
  model           String?
  // Engine session id — Claude session or Codex thread, per provider.
  sessionId       String?
  tokensIn            Int       @default(0)
  tokensOut           Int       @default(0)
  cacheCreationTokens Int       @default(0)
  cacheReadTokens     Int       @default(0)
  numTurns            Int       @default(0)
  durationMs          Int?
  durationApiMs       Int?
  costUsd             Float     @default(0)
  modelUsage          Json?     // Provider-shaped usage detail (Agent SDK modelUsage / Codex turn usage)
  error           String?
  trigger         String    @default("manual") // manual | schedule
  scheduleId      String?
  schedule        Schedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?

  events    RunEvent[]
  artifacts RunArtifact[]

  @@index([taskId])
  @@index([status])
  @@index([scheduleId])
}

enum RunEventType {
  TEXT
  TOOL
  ERROR
  SYSTEM
  ARTIFACT
  STATUS
}

// Polymorphic: an event belongs to EITHER a render TaskRun or a planner
// CampaignPlanRun. Exactly-one-of is enforced in code (the executor that
// creates the event always sets the matching id), not by a DB constraint.
model RunEvent {
  id        String   @id @default(cuid())
  taskRunId String?
  taskRun   TaskRun? @relation(fields: [taskRunId], references: [id], onDelete: Cascade)

  campaignPlanRunId String?
  campaignPlanRun   CampaignPlanRun? @relation(fields: [campaignPlanRunId], references: [id], onDelete: Cascade)

  seq     Int
  type    RunEventType
  payload Json
  ts      DateTime @default(now())

  @@index([taskRunId, seq])
  @@index([campaignPlanRunId, seq])
}

enum ArtifactKind {
  PNG
  HTML
  OTHER
}

model RunArtifact {
  id        String   @id @default(cuid())
  taskRunId String
  taskRun   TaskRun  @relation(fields: [taskRunId], references: [id], onDelete: Cascade)

  kind      ArtifactKind
  filename  String
  relPath   String
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  @@index([taskRunId])
}

// ---------------------------------------------------------------------------
// Campaign Planning — AI plans a multi-day content calendar (phase 1: planner
// run), the user uploads the requested photos, then each planned item renders
// as a normal Task/TaskRun on a bounded schedule.
// ---------------------------------------------------------------------------

enum CampaignStatus {
  DRAFT           // brief captured, planner not run yet
  PLANNING        // planner run queued/running
  REVIEW          // planner produced a draft calendar; user editing
  AWAITING_ASSETS // approved but the asset checklist is unfulfilled
  SCHEDULED       // items materialized with concrete scheduledAt
  RUNNING         // at least one item has fired
  COMPLETED
  CANCELLED
}

enum CampaignItemStatus {
  DRAFT
  SCHEDULED
  RUNNING
  DONE
  FAILED
  CANCELLED
  SKIPPED
}

model Campaign {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  name         String
  brief        String         @default("")
  briefRelPath String?        // set when the brief came from an uploaded/saved file
  status       CampaignStatus @default(DRAFT)
  timezone     String         @default("Asia/Jakarta")

  // Schedule params, captured at approve time.
  startDate    DateTime?
  durationDays Int?     // <= 7, enforced in validation + action
  slotsPerDay  Int?
  slotTimes    String[] @default([]) // HH:mm per slot index

  // The one campaign-level asset folder (reuses AssetFolder / Asset).
  assetFolderId String?
  assetFolder   AssetFolder? @relation(fields: [assetFolderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         CampaignItem[]
  planRuns      CampaignPlanRun[]
  assetRequests CampaignAssetRequest[]

  @@index([workflowId])
  @@index([status])
}

model CampaignItem {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  dayIndex    Int     // 1..durationDays
  slotIndex   Int     // 0-based within a day
  title       String
  angle       String?
  instruction String  @default("")
  caption     String?

  status      CampaignItemStatus @default(DRAFT)
  scheduledAt DateTime?

  // Becomes a real Task on approve; @unique gives Task a one-to-one back-relation.
  taskId    String? @unique
  task      Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  taskRunId String? // the TaskRun the ticker created when this item fired

  // The planner's described per-slot photo needs (references request slugs).
  assetPlan Json?
  assets    CampaignItemAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@index([status])
  @@index([scheduledAt])
}

// Campaign-level "what photos are needed" checklist emitted by the planner.
model CampaignAssetRequest {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  slug        String   // stable ref items point at, e.g. "hero-portrait"
  label       String
  description String   @default("")
  count       Int      @default(1)
  fulfilled   Boolean  @default(false)

  @@index([campaignId])
}

// Per-item resolved manifest: which uploaded Assets this item uses.
model CampaignItemAsset {
  campaignItemId String
  campaignItem   CampaignItem @relation(fields: [campaignItemId], references: [id], onDelete: Cascade)
  assetId        String
  asset          Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([campaignItemId, assetId])
  @@index([assetId])
}

// Phase-1 planner run — lean sibling of TaskRun (no render/artifact fields).
model CampaignPlanRun {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  status RunStatus @default(QUEUED) // reuses the render run status enum
  scope  String    @default("full") // full | reroll | add
  itemId String?                    // target item for reroll/add scopes

  provider            AgentProvider @default(CLAUDE)
  model               String?
  sessionId           String?
  tokensIn            Int           @default(0)
  tokensOut           Int           @default(0)
  cacheCreationTokens Int           @default(0)
  cacheReadTokens     Int           @default(0)
  numTurns            Int           @default(0)
  durationMs          Int?
  durationApiMs       Int?
  costUsd             Float         @default(0)
  modelUsage          Json?
  error               String?

  createdAt  DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?

  events RunEvent[]

  @@index([campaignId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Skills (mirror of .claude/skills/<slug>/SKILL.md)
// ---------------------------------------------------------------------------

model Skill {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @default("")
  content     String   @default("")
  scope       String   @default("PROJECT")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workflowSkills WorkflowSkill[]
}

model WorkflowSkill {
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([workflowId, skillId])
  @@index([skillId])
}

// ---------------------------------------------------------------------------
// Fonts — global Font Bank, assignable per workflow, pickable by the AI
// ---------------------------------------------------------------------------

enum FontSource {
  GOOGLE
  URL
  UPLOAD
}

enum FontCategory {
  SANS
  SERIF
  DISPLAY
  HANDWRITING
  MONOSPACE
  OTHER
}

model Font {
  id          String       @id @default(cuid())
  family      String
  slug        String       @unique
  source      FontSource
  category    FontCategory @default(SANS)
  moodTags    String       @default("")
  previewText String       @default("The quick brown fox")
  enabled     Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  variants       FontVariant[]
  workflowFonts  WorkflowFont[]
  headingPairings FontPairing[] @relation("HeadingFont")
  bodyPairings    FontPairing[] @relation("BodyFont")
}

model FontVariant {
  id     String @id @default(cuid())
  fontId String
  font   Font   @relation(fields: [fontId], references: [id], onDelete: Cascade)

  weight      Int     @default(400)
  weightRange String? // e.g. "100 900" for variable fonts
  style       String  @default("normal") // normal | italic
  format      String  @default("woff2") // woff2 | woff | ttf | otf
  filename    String
  relPath     String

  @@index([fontId])
}

model WorkflowFont {
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fontId     String
  font       Font     @relation(fields: [fontId], references: [id], onDelete: Cascade)
  role       String   @default("any") // any | heading | body

  @@id([workflowId, fontId])
  @@index([fontId])
}

model FontPairing {
  id            String   @id @default(cuid())
  name          String
  headingFontId String
  headingFont   Font     @relation("HeadingFont", fields: [headingFontId], references: [id], onDelete: Cascade)
  bodyFontId    String
  bodyFont      Font     @relation("BodyFont", fields: [bodyFontId], references: [id], onDelete: Cascade)
  moodTags      String   @default("")
  createdAt     DateTime @default(now())
}
