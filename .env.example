# Database — point at your local Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/productivity?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Seeded single user (used by prisma/seed.ts)
SEED_USER_EMAIL="you@example.com"
SEED_USER_PASSWORD="changeme123"
SEED_USER_NAME="You"

# Claude auth. Mode is stored in DB (AppSetting.claudeAuthMode).
# Only used when mode = API_KEY. Empty = use local Claude Code subscription.
ANTHROPIC_API_KEY=""

# Local data root (assets + task outputs)
DATA_ROOT="./data"
